# Passport Photo Pro - Environment Configuration
# Copy this file to .env and fill in your API credentials

# remove.bg API Key
# Get it from: https://www.remove.bg/api
# Free: 50 API calls/month, Paid: $9.99/month for 5000 calls
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# Cloudinary Configuration
# Get it from: https://cloudinary.com/console
# Free tier with generous limits available
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Application Settings (Optional)
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=UTC

# Server Configuration (Optional)
MAX_FILE_SIZE=52428800
MAX_UPLOAD_TIME=300
